# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored — never commit secrets.

# ─── Supabase ─────────────────────────────────────────────────────────────
# https://supabase.com → your project → Project Settings → API

# Public — exposed to the browser. Safe.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only — NEVER expose. Bypasses Row Level Security.
# Used by server actions to write orders and contact leads, and by the admin
# dashboard to read them.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# ─── Admin login ──────────────────────────────────────────────────────────
# These default to admin/admin if you don't override them. CHANGE BEFORE
# DEPLOYING TO PRODUCTION — anyone who guesses these owns your dashboard.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# Random long string used to sign the admin session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Required in production. In dev a fallback is used if unset.
ADMIN_AUTH_SECRET=change-me-to-a-long-random-string

# ─── Email notifications (Resend) ─────────────────────────────────────────
# Optional. If unset, the site still works but no notification emails are sent.
# Sign up at https://resend.com (free 3,000 emails/month, no card required).

RESEND_API_KEY=re_...

# Where to send "new order" / "new contact lead" notifications.
# Comma-separated list to alert multiple addresses.
ADMIN_NOTIFY_EMAIL=you@example.com

# From-address for outgoing notification emails. Defaults to Resend's sandbox
# `onboarding@resend.dev`, which works without domain setup. Set this once you
# verify your own domain in Resend (recommended for deliverability).
# RESEND_FROM_EMAIL="Panchratna <orders@greenraiseagro.com>"

# Public URL of this site, used to put a "View in dashboard" link in emails.
# In Netlify this is automatically set to your deploy URL via $URL — leave it
# unset locally if you don't want the link in dev emails.
NEXT_PUBLIC_SITE_URL=https://your-site.netlify.app
